<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="130dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:layout_margin="6dp"
    android:padding="12dp"
    android:gravity="center"
    android:elevation="2dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/img_barber"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@android:drawable/ic_menu_myplaces"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_barber_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nguyễn Văn A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/tv_barber_specialty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cắt tóc nam"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:layout_marginTop="2dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★"
            android:textColor="#FFC107"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tv_barber_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4.8"
            android:textSize="13sp"
            android:textColor="#212121"
            android:layout_marginStart="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_barber_available"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Còn trống"
        android:textSize="11sp"
        android:textColor="#4CAF50"
        android:background="@drawable/bg_status_chip"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_marginTop="6dp"/>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tên thợ *" android:textStyle="bold" />
        <EditText android:id="@+id/etName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Nhập tên thợ" android:inputType="textPersonName" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chuyên môn" android:textStyle="bold" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etSpecialty"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="VD: Cắt tóc nam, nhuộm..." />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="URL ảnh" android:textStyle="bold" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etImageUrl"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="https://..." android:inputType="textUri" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Rating (0.0 - 5.0)" android:textStyle="bold" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etRating"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="VD: 4.5" android:inputType="numberDecimal" />

        <CheckBox android:id="@+id/cbAvailable"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Đang làm việc" android:layout_marginTop="12dp"
            android:checked="true" />

        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Lưu" android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
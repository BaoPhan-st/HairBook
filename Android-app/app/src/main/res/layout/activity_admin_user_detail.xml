<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Quay lại"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi tiết người dùng"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        android:visibility="gone"/>

    <!-- Content -->
    <ScrollView
        android:id="@+id/layout_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Avatar Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_initial"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:text="A"
                        android:textColor="@color/primary"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_avatar_circle_large"/>

                    <TextView
                        android:id="@+id/tv_full_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nguyễn Văn A"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:id="@+id/tv_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin liên hệ"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Phone -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📱  " android:textSize="14sp"/>
                        <TextView android:id="@+id/tv_phone" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0912345678"
                            android:textColor="@color/text_primary" android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="10dp"/>

                    <!-- Role -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🛡  " android:textSize="14sp"/>
                        <TextView android:id="@+id/tv_role" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="CUSTOMER"
                            android:textColor="@color/text_primary" android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Status -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✅  " android:textSize="14sp"/>
                        <TextView android:id="@+id/tv_status" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="ACTIVE"
                            android:textColor="@color/status_confirmed" android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Created At -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🕒  " android:textSize="14sp"/>
                        <TextView android:id="@+id/tv_created_at" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Tạo lúc: --"
                            android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btn_change_role"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Nâng lên ADMIN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/primary"
                android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btn_toggle_status"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Khoá tài khoản"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/status_cancelled"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>

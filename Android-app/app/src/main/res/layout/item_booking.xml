<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: trạng thái + giờ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_booking_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10:00 - 15/01/2025"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chờ xác nhận"
                android:textSize="12sp"
                android:textColor="#FF9800"
                android:background="@drawable/bg_status_chip"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"/>
        </LinearLayout>

        <!-- Dịch vụ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✂ "
                android:textSize="16sp"
                android:textColor="#7B1FA2"/>

            <TextView
                android:id="@+id/tv_service_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cắt tóc + Gội đầu"
                android:textSize="15sp"
                android:textColor="#212121"/>

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="80.000đ"
                android:textSize="15sp"
                android:textColor="#7B1FA2"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Thợ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 "
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_barber_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nguyễn Văn A"
                android:textSize="14sp"
                android:textColor="#757575"/>
        </LinearLayout>

        <!-- Ghi chú -->
        <TextView
            android:id="@+id/tv_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ghi chú: cắt ngắn hai bên"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Đánh giá của khách (nếu đã đánh giá booking này) -->
        <LinearLayout
            android:id="@+id/layout_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_edittext_rounded"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <RatingBar
                android:id="@+id/rating_bar_review"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:isIndicator="true"
                android:numStars="5"
                android:stepSize="1"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_review_comment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nhận xét của bạn"
                android:textSize="13sp"
                android:textColor="#616161"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="10dp"/>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Huỷ lịch"
                android:textSize="13sp"
                android:backgroundTint="#F5F5F5"
                android:textColor="#F44336"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_payment"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Thanh toán"
                android:textSize="13sp"
                android:backgroundTint="#FF9800"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_review"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Đánh giá"
                android:textSize="13sp"
                android:backgroundTint="#2196F3"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_rebook"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Đặt lại"
                android:textSize="13sp"
                android:backgroundTint="#7B1FA2"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>
        </LinearLayout>


    </LinearLayout>
</androidx.cardview.widget.CardView>
